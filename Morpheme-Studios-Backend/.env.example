# =========================================================================
# Django Core Production Settings
# =========================================================================
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
DJANGO_ALLOWED_HOSTS=morphemestudios.co.uk,www.morphemestudios.co.uk,127.0.0.1,localhost

# =========================================================================
# Database Configurations (aaPanel MySQL)
# =========================================================================
# 1. Map matches settings.py expectations
MYSQL_DATABASE=morphemestudios
MYSQL_USER=morphemestudios
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# 2. Optional modern URL parsing
DATABASE_URL=mysql://morphemestudios:CHANGE_ME_MYSQL_PASSWORD@127.0.0.1:3306/morphemestudios
DB_CONN_MAX_AGE=60

# =========================================================================
# Security & Domains Setup
# =========================================================================
SITE_URL=https://morphemestudios.co.uk
API_URL=https://morphemestudios.co.uk

CORS_ALLOWED_ORIGINS=https://morphemestudios.co.uk,https://www.morphemestudios.co.uk
CSRF_TRUSTED_ORIGINS=https://morphemestudios.co.uk,https://www.morphemestudios.co.uk

JWT_COOKIE_SECURE=True
JWT_COOKIE_SAMESITE=Strict
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# =========================================================================
# Redis & Celery Settings (aaPanel Redis Application)
# =========================================================================
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# =========================================================================
# Email & Logs Setup
# =========================================================================
# Todo: Update these once you hooks the production SMTP credentials
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Morpheme Studios <no-reply@morphemestudios.co.uk>
LEADS_NOTIFY_EMAIL=connect@morphemestudios.co.uk

TURNSTILE_ENABLED=False
TURNSTILE_SECRET_KEY=
LOG_LEVEL=INFO
