# ---------------------------------------------------------------------------
# Morpheme Studios backend — environment template (VPS deployment).
# Copy to `.env` (chmod 600, never commit). On the VPS this file is read by
# both gunicorn (the app) and manage.py commands.
# ---------------------------------------------------------------------------

# Core
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=change-me-to-a-50+-char-random-string
DJANGO_DEBUG=false
# Same-origin architecture: the SPA and the API share the apex domain; the API
# is reachable at https://morphemestudios.com/api/ (Nginx proxies /api -> gunicorn).
DJANGO_ALLOWED_HOSTS=morphemestudios.com,www.morphemestudios.com
SITE_URL=https://morphemestudios.com
API_URL=https://morphemestudios.com

# CORS / CSRF (frontend origins)
CORS_ALLOWED_ORIGINS=https://www.morphemestudios.com,https://morphemestudios.com
CSRF_TRUSTED_ORIGINS=https://www.morphemestudios.com

# Database (local PostgreSQL on the VPS)
DATABASE_URL=postgres://morpheme:CHANGE_ME@127.0.0.1:5432/morpheme_studios
DB_CONN_MAX_AGE=60

# Redis — separate logical DBs: cache=0, Celery broker=1, result=2.
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# JWT / auth
JWT_ACCESS_MIN=15
JWT_REFRESH_DAYS=7
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=Strict
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_MINUTES=15

# Throttling (counts stored in the DB cache table)
THROTTLE_ANON=60/min
THROTTLE_USER=240/min
THROTTLE_FORM=5/min
THROTTLE_LOGIN=5/min

# Email (transactional SMTP — notifications + newsletter sent synchronously)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.postmarkapp.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Morpheme Studios <no-reply@morphemestudios.com>
LEADS_NOTIFY_EMAIL=connect@morphemestudios.com

# Uploads (PDF only; type + size + magic-byte validation, no AV service)
MAX_UPLOAD_BYTES=10485760
MEDIA_SIGNED_URL_TTL=300

# Spam protection (Cloudflare Turnstile)
TURNSTILE_ENABLED=true
TURNSTILE_SECRET_KEY=

# Security headers (extra CSP origins as needed)
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
CSP_EXTRA_IMG_SRC=
# Same-origin API needs no extra connect-src (CSP 'self' covers it).
CSP_EXTRA_CONNECT_SRC=

# Optional Cloudflare R2 media (S3-compatible). Leave blank to store media on
# the VPS disk (served by Nginx).
R2_BUCKET=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO
